{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "SpecDocument",
  "type": "object",
  "required": ["version", "target", "entries"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/entry" }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "required": ["id", "description", "category", "assertion"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": ["file-layout", "public-api", "documentation", "http-contract"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assertion": { "$ref": "#/definitions/assertion" }
      }
    },
    "assertion": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "file-exists",
            "file-contains",
            "type-exists",
            "member-exists",
            "doc-mentions"
          ]
        },
        "path": { "type": "string" },
        "substring": { "type": "string" },
        "typeName": { "type": "string" },
        "memberName": { "type": "string" },
        "signature": { "type": "string" },
        "symbol": { "type": "string" }
      }
    }
  }
}
